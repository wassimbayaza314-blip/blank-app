        "# =========================================================\n",
        "# SYSTEME ELYSIANE DEV - ULTIMATE GLOBAL ENGINE V1.4\n",
        "# =========================================================\n",
        "\n",
        "# Dictionnaire de simulation (Sera connecté aux API officielles sur Bolt)\n",
        "DICTIONNAIRE_PRIX_MONDIAL = {\n",
        "    \"serveur_cloud\": 45.0,\n",
        "    \"licence_logiciel\": 15.0,\n",
        "    \"cable_reseau_10m\": 12.5,\n",
        "    \"routeur_pro\": 120.0\n",
        "}\n",
        "\n",
        "TAUX_DE_CHANGE_OFFICIEL = {\n",
        "    \"EUR\": 1.0, \"USD\": 1.09, \"DZD\": 146.0, \"AED\": 4.0\n",
        "}\n",
        "\n",
        "def generer_estimation_mondiale_pro(client_nom, pays, devise, liste_materiaux, heures_travail, taux_horaire=25, taux_tva=0):\n",
        "    \"\"\"\n",
        "    Moteur financier de classe mondiale avec gestion des devises,\n",
        "    des taxes locales (TVA) et d'une marge de sécurité pour les imprévus.\n",
        "    \"\"\"\n",
        "    cout_materiaux_base = 0.0\n",
        "\n",
        "    # 1. Récupération des prix des matériaux\n",
        "    for m in liste_materiaux:\n",
        "        cout_materiaux_base += DICTIONNAIRE_PRIX_MONDIAL.get(m.lower(), 0.0)\n",
        "\n",
        "    # 2. Ajout d'une marge de sécurité de 10% sur les matériaux (Frais de douane / Imprévus mondiaux)\n",
        "    frais_imprevus_materiaux = cout_materiaux_base * 0.10\n",
        "    cout_materiaux_total_eur = cout_materiaux_base + frais_imprevus_materiaux\n",
        "\n",
        "    # 3. Calcul de la main d'œuvre en EUR\n",
        "    cout_main_doeuvre_eur = heures_travail * taux_horaire\n",
        "\n",
        "    # 4. Coût de revient total en EUR, puis conversion dans la devise cible\n",
        "    cout_production_eur = cout_materiaux_total_eur + cout_main_doeuvre_eur\n",
        "    taux_change = TAUX_DE_CHANGE_OFFICIEL.get(devise, 1.0)\n",
        "\n",
        "    cout_production_local = cout_production_eur * taux_change\n",
        "\n",
        "    # 5. Application de la marge bénéficiaire nette de l'entrepreneur (20%)\n",
        "    marge_profit_local = cout_production_local * 0.20\n",
        "\n",
        "    # 6. Prix Hors Taxe et application de la TVA du pays\n",
        "    prix_ht_local = cout_production_local + marge_profit_local\n",
        "    montant_tva_local = prix_ht_local * (taux_tva / 100)\n",
        "\n",
        "    # Prix final que le client va payer\n",
        "    prix_cle_en_main = prix_ht_local + montant_tva_local\n",
        "\n",
        "    return {\n",
        "        \"Statut\": \"Document Officiel - Elysiane Dev\",\n",
        "        \"Client\": client_nom,\n",
        "        \"Pays Cible\": pays,\n",
        "        \"Devise\": devise,\n",
        "        \"Coût Matériaux (avec 10% sécurité)\": f\"{round(cout_materials_local := cout_materiaux_total_eur * taux_change, 2)} {devise}\",\n",
        "        \"Main d'Œuvre Facturée\": f\"{round(cout_main_doeuvre_eur * taux_change, 2)} {devise}\",\n",
        "        \"VOTRE BÉNÉFICE NET SÉCURISÉ\": f\"{round(marge_profit_local, 2)} {devise}\",\n",
        "        \"TVA locale appliquée\": f\"{taux_tva}% ({round(montant_tva_local, 2)} {devise})\",\n",
        "        \"TOTAL FACTURÉ AU CLIENT (TTC)\": f\"{round(prix_cle_en_main, 2)} {devise}\"\n",
        "    }\n",
        "\n",
        "# =========================================================\n",
        "# TEST DU MOTEUR ULTIME V1.4\n",
        "# =========================================================\n",
        "print(\"--- BANQUE DE DONNÉES ELYSIANE DEV V1.4 --- \\n\")\n",
        "\n",
        "# Test sur un gros projet avec matériel et risques inclus\n",
        "rapport_final = generer_estimation_mondiale_pro(\n",
        "    client_nom=\"Sonatrach Partner\",\n",
        "    pays=\"Algérie\",\n",
        "    devise=\"DZD\",\n",
        "    liste_materiaux=[\"serveur_cloud\", \"routeur_pro\", \"cable_reseau_10m\"],\n",
        "    heures_travail=50,\n",
        "    taux_horaire=40,\n",
        "    taux_tva=19 # TVA officielle en Algérie\n",
        ")\n",
        "\n",
        "for cle, valeur in rapport_final.items():\n",
        "    print(f\"{cle} : {valeur}\")"
